{
    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "main.py",
            "headers": {
                "Access-Control-Allow-Credentials": "true",
                "Access-Control-Allow-Origin": "https://fluid-ai-yqba-boqrgk4jz-pandeyrakshits-projects.vercel.app",
                "Access-Control-Allow-Methods": "GET,DELETE,POST,PUT",
                "Access-Control-Allow-Headers": "Content-Type, Authorization"
            }
        }
    ]
}